{
  "name": "finance-monitor",
  "version": "0.4.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SRV,WEB -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "build:collector": "node scripts/build-collector.mjs",
    "package": "npm run build && node scripts/package-sea.mjs",
    "package:pkg": "npm run build && pkg dist/server.cjs --targets node18-win-x64 --output bin/jp225-monitor",
    "icons": "node scripts/gen-placeholder-icons.mjs",
    "sidecar:copy": "node scripts/copy-sidecar.mjs",
    "collector:copy": "node scripts/copy-collector.mjs",
    "tauri": "tauri",
    "tauri:dev": "node scripts/kill-sidecar.mjs && npm run package && npm run sidecar:copy && npm run build:collector && npm run collector:copy && tauri dev",
    "tauri:build": "node scripts/kill-sidecar.mjs && npm run package && npm run sidecar:copy && npm run build:collector && npm run collector:copy && tauri build",
    "tauri:signer": "tauri signer generate -w ~/.tauri/jp225-monitor.key",
    "release:build": "node scripts/release-build.mjs",
    "release:latest-json": "node scripts/make-latest-json.mjs",
    "basedata:publish": "node scripts/basedata-publish.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "pkg": {
    "scripts": [],
    "assets": [
      "dist/web/**/*"
    ]
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "cheerio": "^1.0.0",
    "express": "^4.19.0",
    "openai": "^4.50.0",
    "rss-parser": "^3.13.0",
    "yahoo-finance2": "^2.11.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/express": "^4.17.0",
    "@types/node": "^20.14.0",
    "@yao-pkg/pkg": "^6.20.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0",
    "xlsx": "^0.18.5"
  }
}
