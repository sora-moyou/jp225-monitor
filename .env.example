# LLM プロバイダ (優先順: Gemini → Groq → OpenAI、429時に自動次へ)
# 1つでも設定すれば動く。複数設定するとフォールバック有効。

# Gemini (無料、品質高、日次1500回): https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-key-here

# Groq (無料、超高速、日次14400回): https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# OpenAI (有料、最後の砦): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

PORT=3000
