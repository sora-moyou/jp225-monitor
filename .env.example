# LLMキー (環境変数名は OPENAI_API_KEY 固定、中身はプロバイダ次第)
# Gemini (default, free): https://aistudio.google.com/apikey で取得した AIza... を貼る
# Groq:   https://console.groq.com/keys で gsk_... を取得 (config.ts の baseURL/model を切替要)
# OpenAI: https://platform.openai.com/api-keys で sk-... を取得 (config.ts の baseURL を undefined に)
OPENAI_API_KEY=AIza-your-key-here
PORT=3000
